{
  "name": "auto-mailer-backend",
  "version": "2.0.0",
  "description": "AutoMailer Pro — Enterprise SaaS Backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:workers": "tsx watch src/workers/worker.bootstrap.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:workers": "node dist/workers/worker.bootstrap.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "echo 'Run database/schema.sql in Supabase SQL Editor'",
    "db:types": "npx supabase gen types typescript --project-id YOUR_PROJECT_ID > src/shared/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "bullmq": "^5.77.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "groq-sdk": "^0.15.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "nodemailer": "^6.10.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/multer": "^1.4.12",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "stripe": "^17.7.0"
  }
}
