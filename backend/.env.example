# ============================================================
# AutoMailer Pro — Backend Environment Configuration v2.0
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Core ──────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# ── Supabase ──────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Redis ─────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST:PORT
# Railway: auto-injected as REDIS_URL

REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ── AI Providers ──────────────────────────────────────────────
# At least one provider should be configured.
# AI_DEFAULT_PROVIDER controls which is tried first.

GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

AI_DEFAULT_PROVIDER=groq

# ── SMTP Credential Encryption ────────────────────────────────
# MUST be 32+ characters. Used to encrypt admin SMTP passwords at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SMTP_ENCRYPTION_SECRET=change_this_to_a_32_character_random_secret_immediately

# ── Security ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://yourapp.com,https://app.yourapp.com

CORS_ALLOWED_ORIGINS=http://localhost:5173
JWT_AUDIENCE=authenticated

# ── Billing / Stripe (Optional) ───────────────────────────────
# Leave commented until FEATURE_BILLING_ENABLED=true

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Feature Flags ─────────────────────────────────────────────
# FEATURE_REDIS_ENABLED=false    — Run without Redis (dev mode, sync email sending)
# FEATURE_BILLING_ENABLED=true   — Enable billing endpoints
# FEATURE_ATTACHMENT_SCAN=true   — Validate attachment MIME types

FEATURE_REDIS_ENABLED=true
FEATURE_BILLING_ENABLED=false
FEATURE_ATTACHMENT_SCAN=true
FEATURE_REALTIME_QUEUE=true

# ── Logging ───────────────────────────────────────────────────
# LOG_LEVEL: trace | debug | info | warn | error | fatal

LOG_LEVEL=debug
